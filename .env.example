# Database connection string
DATABASE_URL=postgresql://user:password@localhost:5432/booking_db

# Session secret for authentication cookies
SESSION_SECRET=your_session_secret

# Port the server runs on
PORT=5005

# Twilio SMS (optional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
TEXTBELT_API_KEY=

# Mailgun Email (optional)
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# MAILGUN_SENDER_EMAIL=

# CORS
CORS_ALLOW_ALL=true
CORS_ORIGINS=http://localhost:5173

# Google OAuth (Business Profile API)
# Get these from Google Cloud Console > APIs & Services > Credentials
# The redirect URI must be registered in Google Cloud Console under "Authorized redirect URIs"
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Development: http://localhost:5005/api/google-business/callback
# Production:  https://yourdomain.com/api/google-business/callback
GOOGLE_REDIRECT_URI=http://localhost:5005/api/google-business/callback
